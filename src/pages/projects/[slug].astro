---
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{project.title} | Pouria Alaei</title>
    <meta name="description" content={project.subtitle} />
  </head>

  <body>
    <main class="page">
      <a class="back" href="/">← Back to home</a>

      <section class="hero">
        <p class="eyebrow">Featured Project</p>
        <h1>{project.title}</h1>
        <p class="subtitle">{project.subtitle}</p>
      </section>

      <section class="section">
        <h2>Project Summary</h2>
        <p>{project.summary}</p>
      </section>

      <section class="section">
        <h2>My Role</h2>
        <p>{project.role}</p>
      </section>

      <section class="section">
        <h2>Technical Stack</h2>
        <div class="tags">
          {project.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </section>

      <section class="section">
        <h2>Impact</h2>
        <p>{project.impact}</p>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #e5eef7;
    background: #07111f;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top right, rgba(20, 184, 166, 0.18), transparent 35%),
      #07111f;
  }

  .page {
    width: min(900px, calc(100% - 40px));
    margin: 0 auto;
    padding: 56px 0 80px;
  }

  .back {
    color: #67e8f9;
    text-decoration: none;
    font-weight: 700;
  }

  .hero {
    margin-top: 48px;
  }

  .eyebrow {
    color: #67e8f9;
    font-weight: 700;
  }

  h1 {
    font-size: clamp(40px, 7vw, 72px);
    line-height: 1;
    margin: 16px 0;
  }

  .subtitle {
    color: #cbd5e1;
    font-size: 21px;
    line-height: 1.7;
  }

  .section {
    margin-top: 48px;
    padding: 28px;
    border-radius: 24px;
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid rgba(148, 163, 184, 0.22);
  }

  h2 {
    margin-top: 0;
    color: #93c5fd;
  }

  p {
    color: #cbd5e1;
    line-height: 1.8;
    font-size: 18px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tags span {
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: rgba(15, 23, 42, 0.75);
    padding: 8px 12px;
    border-radius: 999px;
    color: #cbd5e1;
  }
</style>