---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={`${project.title} | Pouria Alaei`}
  description={project.subtitle}
>
  <main class="page">
    <section class="section hero">
      <a class="back" href="/projects">← Back to projects</a>

      <p class="eyebrow">Featured Project</p>
      <h1>{project.title}</h1>
      <p class="lead">{project.subtitle}</p>

      <div class="tags hero-tags">
        {project.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </section>

    <section class="case-study">
      <article class="card">
        <h2>Overview</h2>
        <p>{project.summary}</p>
      </article>

      <article class="card">
        <h2>Engineering Challenge</h2>
        <p>{project.problem}</p>
      </article>

      <article class="card">
        <h2>My Role</h2>
        <p>{project.role}</p>
      </article>

      <article class="card">
        <h2>Key Engineering Work</h2>
        <ul>
          {project.keyWork.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="card">
        <h2>Result / Impact</h2>
        <p>{project.impact}</p>
      </article>

      <article class="card">
        <h2>Images</h2>
        {project.gallery.length > 0 ? (
          <div class="gallery">
            {project.gallery.map((image) => (
              <img src={image} alt={`${project.title} project image`} loading="lazy" />
            ))}
          </div>
        ) : (
          <p class="muted">
            Project images, Altium screenshots, and real hardware photos will be added after
            confidentiality review.
          </p>
        )}
      </article>

      <article class="card note">
        <h2>Confidentiality Note</h2>
        <p>{project.confidentialityNote}</p>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding-bottom: 32px;
  }

  .back {
    display: inline-block;
    margin-bottom: 32px;
    color: #67e8f9;
    text-decoration: none;
    font-weight: 700;
  }

  .eyebrow {
    color: #67e8f9;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  h1 {
    max-width: 980px;
    margin: 12px 0 0;
    font-size: clamp(40px, 7vw, 72px);
    line-height: 1.05;
  }

  .lead {
    max-width: 780px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.7;
  }

  .hero-tags {
    margin-top: 28px;
  }

  .case-study {
    display: grid;
    gap: 18px;
    padding-bottom: 80px;
  }

  h2 {
    margin-top: 0;
    color: #93c5fd;
  }

  p,
  li {
    color: #cbd5e1;
    line-height: 1.7;
  }

  ul {
    margin: 0;
    padding-left: 20px;
  }

  li + li {
    margin-top: 10px;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .gallery img {
    width: 100%;
    border-radius: 16px;
    border: 1px solid rgba(148, 163, 184, 0.22);
  }

  .note {
    border-color: rgba(103, 232, 249, 0.25);
  }
</style>
