---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={`${project.title} | Pouria Alaei`}
  description={project.subtitle ?? project.summary}
>
  <main class="page">
    <section class="section hero">
      <a class="back" href="/projects">← Back to projects</a>

      <p class="eyebrow">Featured Project</p>
      <h1>{project.title}</h1>
      <p class="lead">{project.subtitle ?? project.summary}</p>
    </section>

    <section class="content">
      <article class="card">
        <h2>Project Summary</h2>
        <p>{project.summary}</p>
      </article>

      <article class="card">
        <h2>My Role</h2>
        <p>{project.role}</p>
      </article>

      <article class="card">
        <h2>Technical Stack</h2>
        <div class="tags">
          {project.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </article>

      <article class="card">
        <h2>Impact</h2>
        <p>{project.impact}</p>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding-bottom: 32px;
  }

  .back {
    display: inline-block;
    margin-bottom: 32px;
    color: #67e8f9;
    text-decoration: none;
    font-weight: 700;
  }

  .eyebrow {
    color: #67e8f9;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  h1 {
    max-width: 900px;
    margin: 12px 0 0;
    font-size: clamp(40px, 7vw, 72px);
    line-height: 1.05;
  }

  .lead {
    max-width: 760px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.7;
  }

  .content {
    display: grid;
    gap: 18px;
    padding-bottom: 80px;
  }

  h2 {
    margin-top: 0;
    color: #93c5fd;
  }

  p {
    color: #cbd5e1;
    line-height: 1.7;
  }
</style>
