---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";
---

<BaseLayout
  title="Projects | Pouria Alaei"
  description="Selected embedded systems, Embedded Linux, Edge AI, and hardware/software integration projects by Pouria Alaei."
>
  <main class="page">
    <section class="section intro">
      <p class="eyebrow">Selected Work</p>
      <h1>Projects</h1>
      <p class="lead">
        A selection of production-oriented embedded systems, industrial devices,
        communication platforms, and hardware/software integration projects.
      </p>
    </section>

    <section class="projects-grid">
      {projects.map((project) => (
        <a class="project-card" href={`/projects/${project.slug}`}>
          <article class="card">
            <h2>{project.title}</h2>
            <p>{project.summary}</p>

            <div class="tags">
              {project.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </article>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .intro {
    padding-bottom: 32px;
  }

  .eyebrow {
    color: #67e8f9;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  h1 {
    margin: 12px 0 0;
    font-size: clamp(44px, 7vw, 76px);
    line-height: 1;
  }

  .lead {
    max-width: 760px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.7;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
    padding-bottom: 80px;
  }

  .project-card {
    text-decoration: none;
  }

  .project-card .card {
    height: 100%;
    transition:
      transform 160ms ease,
      border-color 160ms ease;
  }

  .project-card:hover .card {
    transform: translateY(-4px);
    border-color: rgba(103, 232, 249, 0.55);
  }

  h2 {
    margin: 0;
    font-size: 22px;
  }

  p {
    color: #cbd5e1;
    line-height: 1.65;
  }
</style>
