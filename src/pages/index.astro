---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";

const expertise = [
  "Embedded Linux",
  "C/C++",
  "Qt HMI",
  "Firmware",
  "Industrial IoT",
  "Hardware/Software Integration",
  "Networking",
  "Cellular Communication",
  "Edge AI",
  "System Architecture",
];

const focusAreas = [
  {
    title: "Embedded Linux Platforms",
    description:
      "Linux-based device software, local HMI, system services, networking, configuration interfaces, and production-oriented integration.",
  },
  {
    title: "Hardware/Software Integration",
    description:
      "Bringing up real hardware, integrating IO, communication modules, sensors, embedded boards, and debugging behavior across system layers.",
  },
  {
    title: "Industrial Embedded Systems",
    description:
      "Practical embedded products such as vending machines, conference systems, dataloggers, generator controllers, and connected industrial devices.",
  },
  {
    title: "Edge AI and Intelligent Devices",
    description:
      "Embedded systems that combine AI/robotics background with real hardware constraints, device-level software, and edge deployment needs.",
  },
];
---

<BaseLayout
  title={site.title}
  description={site.description}
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">{site.tagline}</p>

      <h1>{site.name}</h1>
      <h2>{site.role}</h2>

      <p class="summary">
        {site.summary}
      </p>

      <div class="links">
        <a class="button" href={`mailto:${site.email}`}>Email</a>
        <a class="button secondary" href={site.linkedin} target="_blank">LinkedIn</a>
        <a class="button secondary" href={site.github} target="_blank">GitHub</a>
        <a class="button secondary" href={site.telegram} target="_blank">Telegram</a>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h3 class="section-title">What I Build</h3>
          <p class="muted">
            Product-level embedded systems that connect software, electronics,
            Linux, connectivity, and real-world operation.
          </p>
        </div>
      </div>

      <div class="focus-grid">
        {focusAreas.map((area) => (
          <article class="card">
            <h4>{area.title}</h4>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <h3 class="section-title">Core Expertise</h3>

      <div class="skills">
        {expertise.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h3 class="section-title">Featured Projects</h3>
          <p class="muted">
            Selected embedded systems, industrial devices, and hardware/software
            integration projects.
          </p>
        </div>

        <a class="text-link" href="/projects">View all projects →</a>
      </div>

      <div class="projects">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding: 72px 0 56px;
  }

  .eyebrow {
    color: #67e8f9;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  h1 {
    margin: 16px 0 0;
    font-size: clamp(48px, 8vw, 88px);
    line-height: 0.95;
  }

  h2 {
    margin: 16px 0 0;
    font-size: clamp(24px, 4vw, 40px);
    color: #93c5fd;
    font-weight: 600;
  }

  .summary {
    max-width: 760px;
    margin-top: 24px;
    font-size: 20px;
    line-height: 1.7;
    color: #cbd5e1;
  }

  .links {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  .section-header p {
    margin: 0;
    max-width: 760px;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
  }

  .focus-grid h4 {
    margin: 0;
    font-size: 20px;
  }

  .focus-grid p {
    color: #cbd5e1;
    line-height: 1.65;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .skills span {
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: rgba(15, 23, 42, 0.75);
    padding: 8px 12px;
    border-radius: 999px;
    color: #cbd5e1;
  }

  .text-link {
    color: #67e8f9;
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
  }

  .projects {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
  }

  @media (max-width: 720px) {
    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
