---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
---

<BaseLayout
  title={site.title}
  description={site.description}
>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">{site.tagline}</p>

      <h1>{site.name}</h1>
      <h2>{site.role}</h2>

      <p class="summary">
        {site.summary}
      </p>

      <div class="links">
        <a class="button" href={`mailto:${site.email}`}>Email</a>
        <a class="button secondary" href={site.linkedin} target="_blank">LinkedIn</a>
        <a class="button secondary" href={site.github} target="_blank">GitHub</a>
        <a class="button secondary" href={site.telegram} target="_blank">Telegram</a>
      </div>
    </section>

    <section class="section">
      <h3 class="section-title">Core Expertise</h3>

      <div class="skills">
        <span>Embedded Linux</span>
        <span>C/C++</span>
        <span>Qt</span>
        <span>Edge AI</span>
        <span>Hardware/Software Integration</span>
        <span>Industrial IoT</span>
        <span>Firmware</span>
        <span>Networking</span>
        <span>System Architecture</span>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h3 class="section-title">Featured Projects</h3>
          <p class="muted">
            Selected embedded systems, industrial devices, and hardware/software integration projects.
          </p>
        </div>

        <a class="text-link" href="/projects">View all projects →</a>
      </div>

      <div class="projects">
        {projects.map((project) => (
          <a class="project-card" href={`/projects/${project.slug}`}>
            <article class="card">
              <h4>{project.title}</h4>
              <p>{project.summary}</p>

              <div class="tags">
                {project.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding: 72px 0 56px;
  }

  .eyebrow {
    color: #67e8f9;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  h1 {
    margin: 16px 0 0;
    font-size: clamp(48px, 8vw, 88px);
    line-height: 0.95;
  }

  h2 {
    margin: 16px 0 0;
    font-size: clamp(24px, 4vw, 40px);
    color: #93c5fd;
    font-weight: 600;
  }

  .summary {
    max-width: 720px;
    margin-top: 24px;
    font-size: 20px;
    line-height: 1.7;
    color: #cbd5e1;
  }

  .links {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .skills span {
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: rgba(15, 23, 42, 0.75);
    padding: 8px 12px;
    border-radius: 999px;
    color: #cbd5e1;
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  .section-header p {
    margin: 0;
  }

  .text-link {
    color: #67e8f9;
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
  }

  .projects {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
  }

  .project-card {
    text-decoration: none;
    display: block;
  }

  .project-card .card {
    height: 100%;
    transition:
      transform 160ms ease,
      border-color 160ms ease;
  }

  .project-card:hover .card {
    transform: translateY(-4px);
    border-color: rgba(103, 232, 249, 0.55);
  }

  .card h4 {
    margin: 0;
    font-size: 20px;
  }

  .card p {
    color: #cbd5e1;
    line-height: 1.65;
  }

  @media (max-width: 720px) {
    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
