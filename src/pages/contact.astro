---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout
  title={`Contact | ${site.name}`}
  description={`Contact ${site.name} for embedded systems, Embedded Linux, Edge AI, and hardware/software integration opportunities.`}
>
  <main class="page">
    <section class="section intro">
      <p class="eyebrow">Contact</p>
      <h1>Let’s connect.</h1>
      <p class="lead">
        I am open to relevant embedded systems, Embedded Linux, Edge AI,
        industrial IoT, and hardware/software integration opportunities.
      </p>

      <div class="actions">
        <a class="button" href={`mailto:${site.email}`}>Email Me</a>
        <a class="button secondary" href={site.linkedin} target="_blank">LinkedIn</a>
        <a class="button secondary" href={site.telegram} target="_blank">Telegram</a>
      </div>
    </section>

    <section class="content-grid">
      <article class="card">
        <h2>Email</h2>
        <p>
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
      </article>

      <article class="card">
        <h2>LinkedIn</h2>
        <p>
          <a href={site.linkedin} target="_blank">LinkedIn Profile</a>
        </p>
      </article>

      <article class="card">
        <h2>GitHub</h2>
        <p>
          <a href={site.github} target="_blank">github.com/pouria-alaei</a>
        </p>
      </article>

      <article class="card">
        <h2>Telegram</h2>
        <p>
          <a href={site.telegram} target="_blank">@Pooria_Alaei</a>
        </p>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .eyebrow {
    color: #67e8f9;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  h1 {
    margin: 12px 0 0;
    font-size: clamp(48px, 8vw, 88px);
    line-height: 1;
  }

  .lead {
    max-width: 760px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    padding-bottom: 80px;
  }

  h2 {
    margin-top: 0;
    color: #93c5fd;
  }

  p,
  a {
    color: #cbd5e1;
    line-height: 1.7;
  }
</style>
