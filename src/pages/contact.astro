---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout
  title={`Contact | ${site.name}`}
  description={`Contact ${site.name} for Embedded Linux, Edge AI, industrial embedded systems, and hardware/software integration opportunities.`}
>
  <main class="page">
    <section class="section intro">
      <p class="eyebrow">Contact</p>
      <h1>Let’s connect.</h1>

      <p class="lead">
        I am open to relevant engineering opportunities in Embedded Linux,
        embedded software, industrial IoT, edge AI, firmware, and hardware/software
        integration.
      </p>

      <div class="actions">
        <a class="button" href={`mailto:${site.email}`}>Email Me</a>
        <a class="button secondary" href={site.linkedin} target="_blank">LinkedIn</a>
        <a class="button secondary" href={site.telegram} target="_blank">Telegram</a>
      </div>
    </section>

    <section class="content-grid">
      <article class="card primary">
        <h2>Best Contact</h2>
        <p>
          For professional opportunities, technical discussions, or collaboration,
          email is the best way to contact me.
        </p>
        <a class="contact-link" href={`mailto:${site.email}`}>{site.email}</a>
      </article>

      <article class="card">
        <h2>LinkedIn</h2>
        <p>
          Connect with me professionally and view my career profile.
        </p>
        <a class="contact-link" href={site.linkedin} target="_blank">
          linkedin.com/in/pouria-alaeinezhad
        </a>
      </article>

      <article class="card">
        <h2>GitHub</h2>
        <p>
          View my public repositories and engineering portfolio source.
        </p>
        <a class="contact-link" href={site.github} target="_blank">
          github.com/pouria-alaei
        </a>
      </article>

      <article class="card">
        <h2>Telegram</h2>
        <p>
          For quick messages and direct communication.
        </p>
        <a class="contact-link" href={site.telegram} target="_blank">
          @Pooria_Alaei
        </a>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .eyebrow {
    color: #67e8f9;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  h1 {
    margin: 12px 0 0;
    font-size: clamp(48px, 8vw, 88px);
    line-height: 1;
  }

  .lead {
    max-width: 780px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    padding-bottom: 80px;
  }

  .primary {
    border-color: rgba(103, 232, 249, 0.35);
  }

  h2 {
    margin-top: 0;
    color: #93c5fd;
  }

  p {
    color: #cbd5e1;
    line-height: 1.7;
  }

  .contact-link {
    display: inline-block;
    margin-top: 8px;
    color: #67e8f9;
    font-weight: 700;
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  .contact-link:hover {
    text-decoration: underline;
  }
</style>
