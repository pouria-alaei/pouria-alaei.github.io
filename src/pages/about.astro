---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout
  title={`About | ${site.name}`}
  description={`About ${site.name}, Senior Embedded Software Engineer focused on Embedded Linux, Edge AI, and hardware/software integration.`}
>
  <main class="page">
    <section class="section intro">
      <p class="eyebrow">About</p>
      <h1>Engineering embedded products from hardware to software.</h1>

      <p class="lead">
        I am a Senior Embedded Software Engineer focused on building practical,
        production-ready embedded systems that connect electronics, firmware,
        Embedded Linux, user interfaces, networking, and intelligent edge applications.
      </p>
    </section>

    <section class="content-grid">
      <article class="card">
        <h2>Engineering Profile</h2>
        <p>
          My work sits at the intersection of embedded software and hardware.
          I design and integrate systems where firmware, Linux services, device
          interfaces, communication modules, industrial IO, and user-facing software
          must work together reliably.
        </p>
      </article>

      <article class="card">
        <h2>Core Strengths</h2>
        <p>
          I have hands-on experience with Embedded Linux, C/C++, Qt-based HMI,
          industrial IoT devices, cellular communication, hardware bring-up,
          system debugging, and hardware/software integration for real products.
        </p>
      </article>

      <article class="card">
        <h2>Edge AI and Robotics Background</h2>
        <p>
          With an academic background in Electrical Engineering, AI, and Robotics,
          I am especially interested in edge AI systems, intelligent devices,
          computer vision applications, and practical embedded platforms that bring
          intelligence closer to the hardware.
        </p>
      </article>

      <article class="card">
        <h2>Technical Leadership</h2>
        <p>
          I also work as a technical lead, turning product requirements into
          engineering plans, coordinating hardware and software decisions, reviewing
          implementation risks, and helping teams move from prototype to deployable
          embedded systems.
        </p>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .eyebrow {
    color: #67e8f9;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  h1 {
    max-width: 980px;
    margin: 12px 0 0;
    font-size: clamp(42px, 7vw, 72px);
    line-height: 1.05;
  }

  .lead {
    max-width: 820px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.7;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    padding-bottom: 80px;
  }

  h2 {
    margin-top: 0;
    color: #93c5fd;
  }

  p {
    color: #cbd5e1;
    line-height: 1.7;
  }
</style>
