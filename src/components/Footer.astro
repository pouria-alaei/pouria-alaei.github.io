---
import { site } from "../data/site";

const year = new Date().getFullYear();

const links = [
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/experience", label: "Experience" },
  { href: "/contact", label: "Contact" },
];

const socialLinks = [
  { href: site.linkedin, label: "LinkedIn" },
  { href: site.github, label: "GitHub" },
  { href: site.telegram, label: "Telegram" },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-main">
      <div>
        <a class="footer-brand" href="/">{site.name}</a>
        <p>
          Senior Embedded Software Engineer focused on Embedded Linux, Edge AI,
          industrial embedded systems, and hardware/software integration.
        </p>
      </div>

      <div class="footer-column">
        <h2>Navigation</h2>
        {links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>

      <div class="footer-column">
        <h2>Connect</h2>
        <a href={`mailto:${site.email}`}>Email</a>
        {socialLinks.map((link) => (
          <a href={link.href} target="_blank">{link.label}</a>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} {site.name}. All rights reserved.</span>
      <span>Built with Astro and GitHub Pages.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    background: rgba(2, 6, 23, 0.55);
  }

  .footer-inner {
    width: min(var(--container), calc(100% - 40px));
    margin: 0 auto;
    padding: 42px 0 28px;
  }

  .footer-main {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) 180px 180px;
    gap: 32px;
  }

  .footer-brand {
    display: inline-block;
    color: #e5eef7;
    text-decoration: none;
    font-weight: 900;
    font-size: 22px;
    margin-bottom: 10px;
  }

  p {
    max-width: 560px;
    color: #94a3b8;
    line-height: 1.7;
    margin: 0;
  }

  .footer-column {
    display: grid;
    gap: 10px;
    align-content: start;
  }

  h2 {
    margin: 0 0 6px;
    color: #67e8f9;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .footer-column a {
    color: #cbd5e1;
    text-decoration: none;
    font-weight: 650;
  }

  .footer-column a:hover {
    color: #67e8f9;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
    margin-top: 36px;
    padding-top: 22px;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    color: #64748b;
    font-size: 14px;
  }

  @media (max-width: 780px) {
    .footer-inner {
      width: min(100% - 28px, var(--container));
    }

    .footer-main {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
