---
import { contact } from "../data/contact";
---

<footer class="footer">
  <div>
    <strong>Pouria Alaei</strong>
    <p>Embedded Linux • Edge AI • Hardware/Software Integration</p>
  </div>

  <div class="links">
    <a href={`mailto:${contact.email}`}>Email</a>
    <a href={contact.linkedin} target="_blank">LinkedIn</a>
    <a href={contact.github} target="_blank">GitHub</a>
    <a href={contact.telegram} target="_blank">Telegram</a>
  </div>
</footer>

<style>
  .footer {
    width: min(1100px, calc(100% - 40px));
    margin: 0 auto;
    padding: 40px 0;
    border-top: 1px solid rgba(148, 163, 184, 0.18);
    display: flex;
    justify-content: space-between;
    gap: 24px;
    color: #cbd5e1;
  }

  .footer p {
    margin: 8px 0 0;
  }

  .links {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .links a {
    color: #67e8f9;
    text-decoration: none;
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .footer {
      flex-direction: column;
    }
  }
</style>
