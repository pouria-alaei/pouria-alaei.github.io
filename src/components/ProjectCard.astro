---
import type { PortfolioProject } from "../data/projects";

type Props = {
  project: PortfolioProject;
  label?: string;
};

const { project, label = "Case Study" } = Astro.props;
const hasCover = Boolean(project.cover);
---

<a class="project-card" href={`/projects/${project.slug}`}>
  <article class="card">
    {hasCover ? (
      <img class="cover" src={project.cover} alt={`${project.title} cover image`} loading="lazy" />
    ) : (
      <div class="cover-placeholder">
        <span>{project.tags[0]}</span>
      </div>
    )}

    <div class="card-top">
      <p class="project-label">{label}</p>
      <span>→</span>
    </div>

    <h4>{project.title}</h4>
    <p>{project.summary}</p>

    <div class="tags">
      {project.tags.map((tag) => <span>{tag}</span>)}
    </div>
  </article>
</a>

<style>
  .project-card {
    text-decoration: none;
    display: block;
  }

  .project-card .card {
    height: 100%;
    overflow: hidden;
    transition:
      transform 160ms ease,
      border-color 160ms ease;
  }

  .project-card:hover .card {
    transform: translateY(-4px);
    border-color: rgba(103, 232, 249, 0.55);
  }

  .cover,
  .cover-placeholder {
    width: calc(100% + 48px);
    margin: -24px -24px 22px;
    height: 170px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.22);
  }

  .cover {
    object-fit: cover;
    display: block;
    background: rgba(2, 6, 23, 0.55);
  }

  .cover-placeholder {
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at top right, rgba(103, 232, 249, 0.16), transparent 35%),
      linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(20, 184, 166, 0.08)),
      rgba(2, 6, 23, 0.55);
  }

  .cover-placeholder span {
    color: #67e8f9;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 12px;
    text-align: center;
    padding: 0 20px;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #67e8f9;
    font-weight: 800;
    margin-bottom: 16px;
  }

  .project-label {
    margin: 0;
    color: #67e8f9;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h4 {
    margin: 0;
    font-size: 20px;
    color: #e5eef7;
  }

  p {
    color: #cbd5e1;
    line-height: 1.65;
  }
</style>
