---
const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/experience", label: "Experience" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;
---

<header class="navbar">
  <a class="brand" href="/">Pouria Alaei</a>

  <nav>
    {links.map((link) => (
      <a class={pathname === link.href ? "active" : ""} href={link.href}>
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .navbar {
    width: min(1100px, calc(100% - 40px));
    margin: 0 auto;
    padding: 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    text-decoration: none;
    font-weight: 800;
    letter-spacing: -0.03em;
    font-size: 20px;
  }

  nav {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  nav a {
    text-decoration: none;
    color: #cbd5e1;
    font-weight: 600;
    font-size: 14px;
  }

  nav a.active,
  nav a:hover {
    color: #67e8f9;
  }

  @media (max-width: 720px) {
    .navbar {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>